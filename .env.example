# ══════════════════════════════════════════════════════════════
# 帝王系统 · 环境变量配置示例
# ══════════════════════════════════════════════════════════════

# ─── OpenClaw 路径配置 ────────────────────────────────────────
# OpenClaw 安装目录，默认为 ~/.openclaw
# 在 Docker 容器或多用户环境中可以自定义此路径
OPENCLAW_HOME=/path/to/openclaw

# ─── 项目路径配置 ─────────────────────────────────────────────
# 帝王系统项目根目录，默认为脚本所在目录
REPO_DIR=/path/to/claw-diwang

# ─── 使用示例 ─────────────────────────────────────────────────
# 1. 复制此文件为 .env
#    cp .env.example .env
#
# 2. 修改配置值
#    vim .env
#
# 3. 加载环境变量
#    source .env
#
# 4. 运行安装脚本
#    ./install.sh
#
# 5. 启动数据刷新循环
#    bash scripts/run_loop.sh &

# ─── Docker 环境示例 ──────────────────────────────────────────
# 在 docker-compose.yml 中使用：
#
# services:
#   diwang:
#     environment:
#       - OPENCLAW_HOME=/app/.openclaw
#       - REPO_DIR=/app/claw-diwang

# SLS 配置示例文件
# 复制为 ~/.sls.conf 或 data/sls.conf，填写真实配置后使用
# ⚠️ 严禁将含真实 AK 的配置文件提交到代码仓库！
#
# 环境变量方式（推荐 CI/CD 场景）：
#   export SLS_ENDPOINT=cn-hangzhou.log.aliyuncs.com
#   export SLS_AK_ID=YOUR_AK_ID
#   export SLS_AK_SECRET=YOUR_AK_SECRET
#   export SLS_PROJECT=your-project
#   export SLS_LOGSTORE=your-logstore

[sls]
# SLS 接入地址
# 格式: <region>.log.aliyuncs.com
# 常用区域: cn-hangzhou / cn-beijing / cn-shanghai / ap-southeast-1
endpoint = cn-hangzhou.log.aliyuncs.com

# 阿里云 AccessKey ID
# 建议使用 RAM 子账号，最小权限: log:GetLogStore, log:GetLogs, log:ListLogStores
ak_id = YOUR_ACCESS_KEY_ID

# 阿里云 AccessKey Secret
ak_secret = YOUR_ACCESS_KEY_SECRET

# SLS Project 名称
project = your-project-name

# 默认 Logstore 名称（可在命令行用 --logstore 覆盖）
logstore = your-app-logstore
